# Adyen Test configuration. Keep real values only in your uncommitted .env file.
ADYEN_API_KEY=replace-with-your-adyen-test-api-key
ADYEN_MERCHANT_ACCOUNT=replace-with-your-merchant-account
ADYEN_CLIENT_KEY=replace-with-your-client-key
ADYEN_ENVIRONMENT=TEST
ADYEN_HMAC_KEY=replace-with-your-webhook-hmac-key
